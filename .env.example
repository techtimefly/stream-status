# AI provider config — copy to /opt/stream-status/.env and fill in values.
# The service starts normally with no .env file; AI features are simply disabled.

# Option A: Anthropic (Claude Haiku). Takes priority when set.
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: Ollama (local/LAN). Used when ANTHROPIC_API_KEY is not set.
# OLLAMA_BASE_URL=http://<OLLAMA_HOST_IP>:11434
# OLLAMA_MODEL=gemma4
